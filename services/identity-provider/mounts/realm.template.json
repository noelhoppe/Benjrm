{
  "realm": "${KC_REALM_ID}",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": true,
  "resetPasswordAllowed": true,
  "verifyEmail": true,
  "rememberMe": true,
  "smtpServer": {
    "from": "${KC_SMTP_SERVER_FROM}",
    "host": "${KC_SMTP_SERVER_HOST}",
    "port": "${KC_SMTP_SERVER_PORT}",
    "ssl": "${KC_SMTP_SERVER_SSL}",
    "auth": "${KC_SMTP_SERVER_AUTH}",
    "password": "${KC_SMTP_SERVER_PASSWORD}",
    "user": "${KC_SMTP_SERVER_USER}"
  },
  "clients": [
    {
      "clientId": "web",
      "name": "Client-side Web Application",
      "description": "Client-side Web Application of Benjrm",
      "publicClient": true,
      "standardFlowEnabled": true,
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "${KC_CLIENTID_WEB_ATTRIBUTES_POST_LOGOUT_REDIRECT_URIS}"
      },
      "rootUrl": "${KC_CLIENTID_WEB_ROOT_URL}",
      "baseUrl": "${KC_CLIENTID_WEB_BASE_URL}",
      "redirectUris": [
        "${KC_CLIENTID_WEB_REDIRECT_URIS}"
      ],
      "webOrigins": [
        "${KC_CLIENTID_WEB_WEB_ORIGINS}"
      ]
    },
    {
      "clientId": "api",
      "name": "Server-side API",
      "description": "Server-side API of Benjrm",
      "publicClient": false,
      "standardFlowEnabled": false,
      "serviceAccountsEnabled": true,
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "rootUrl": "${KC_CLIENTID_API_ROOT_URL}",
      "baseUrl": "${KC_CLIENTID_API_BASE_URL}",
      "secret": "${KC_CLIENTID_API_CLIENT_SECRET}"
    }
  ]
}