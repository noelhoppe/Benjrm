ARG NODE_VERSION=24-bookworm-slim
ARG APP_UID=1000
ARG APP_GID=1000

FROM node:${NODE_VERSION} AS dev

ARG APP_UID
ARG APP_GID

WORKDIR /app

RUN groupmod --gid "${APP_GID}" node \
	&& usermod --uid "${APP_UID}" --gid "${APP_GID}" node

COPY --chown=node:node package*.json ./

USER node

RUN --mount=type=cache,target=/home/node/.npm npm ci

COPY --chown=node:node . .

EXPOSE 5173

# In development, we run the vite server for hot reload. So we need to bind to 0.0.0.0 to allow access from outside the container.
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]